vars: { d2-config: { layout-engine: elk } }
direction: right

title: |md
  ## JI as-is schema — Bookings & Sittings
  PK / FK (in-area) / UNQ markers · trigger badges `[B/A × I/U/D]` · intra-area FK edges only · cross-area & external refs shown in the type cell
| { near: top-center; style.font-size: 22 }

TBL_JI_FP_BOOKINGS: "TBL_JI_FP_BOOKINGS [BI]" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_FP_BOOKING_ID: "NUMBER" {constraint: [primary_key]}
  JI_PLANNED_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_PLANNED_WORK_TYPES"
  JI_ABS_OB_ID: "NUMBER → TBL_JI_ABS_OB"
  JUDGE_CODE: "NUMBER(6,0) → TBL_JUDGES"
  START_DATE: "DATE"
  END_DATE: "DATE"
  START_SITTING_DUR_ID: "NUMBER(2,0)"
  END_SITTING_DUR_ID: "NUMBER(2,0)"
  WORKING_DAYS: "NUMBER(5,2)"
  COMMENTS: "VARCHAR2(4000)"
  CREATED_BY: "VARCHAR2(255)"
  CREATED_DATE: "DATE"
  LAST_MODIFIED_BY: "VARCHAR2(255)"
  LAST_MODIFIED_DATE: "DATE"
  CONFIRMED_BY: "VARCHAR2(255)"
  CONFIRMED_DATE: "DATE"
  CANCELLED: "CHAR(1)"
  ACKNOWLEDGED_BY: "VARCHAR2(255)"
  ACKNOWLEDGED_DATE: "DATE"
  LOC_TYPE_ID: "NUMBER(2,0) → LOCATION TYPES"
  LOC_ID: "NUMBER(6,0) → LOCATIONS / OFFICES"
  JUDGE_TICKET_TYPE_ID: "NUMBER(3,0) → TBL_JUDGE_TICKET_TYPES"
  CANCELLED_BY: "VARCHAR2(255)"
  CANCELLED_DATE: "DATE"
  CANCELLED_OTHER_REASON: "VARCHAR2(4000)"
  JI_CHANGE_FROM_ID: "NUMBER"
  JI_CHANGE_TO_ID: "NUMBER"
  JI_FP_BOOKING_TYPE_ID: "NUMBER(2,0)" {constraint: [foreign_key]}
  JI_FP_CANCELLER_ID: "NUMBER(2,0)" {constraint: [foreign_key]}
  EMAIL_SENT: "CHAR(1)"
  CANCEL_EMAIL_SENT: "CHAR(1)"
  CANCEL_ACKN_SENT: "DATE"
  FEE_PAYABLE: "CHAR(1)"
  CUT_OWNER_ID: "NUMBER → COURTROOMS / CUT_*"
  LATE_CANCELLATION: "CHAR(1)"
  SEND_AMEND_EMAIL: "CHAR(1)"
  AMEND_ACKN_SENT: "DATE"
  APPRAISAL: "CHAR(1)"
  HEARING_LOC_TYPE_ID: "NUMBER(2,0) → LOCATION TYPES"
  HEARING_LOC_ID: "NUMBER(6,0) → LOCATIONS"
  TOTAL_FEE_AMT: "NUMBER(8,2)"
  BOOKED_OVER_MAX: "CHAR(1)"
}

TBL_JI_FP_BOOKING_DETAIL: "TBL_JI_FP_BOOKING_DETAIL [BI BU]" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_FP_BOOKING_DETAIL_ID: "NUMBER" {constraint: [primary_key]}
  JI_FP_BOOKING_ID: "NUMBER" {constraint: [foreign_key]}
  FP_BOOKING_DATE: "DATE"
  YEARMONTH: "NUMBER(6,0)"
  SITTING_DUR_ID: "NUMBER(2,0)"
  ABS_OB_JUDGE_CODE: "NUMBER(6,0) → TBL_JUDGES"
  CUT_OWNER_ID: "NUMBER → COURTROOMS / CUT_*"
  JI_PLANNED_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_PLANNED_WORK_TYPES"
  JI_VACANCY_ID: "NUMBER → TBL_JI_VACANCIES"
  COMMENTS: "VARCHAR2(4000)"
  JUDGE_TICKET_TYPE_ID: "NUMBER(2,0) → TBL_JUDGE_TICKET_TYPES"
  CONFIRMED_BY: "VARCHAR2(255)"
  CONFIRMED_DATE: "DATE"
  JI_ACTUAL_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_ACTUAL_WORK_TYPES"
  FEE_AMT: "NUMBER(6,2)"
  T_AND_S_AMT: "NUMBER(6,2)"
  PAYMENT_CONFIRMED_BY: "VARCHAR2(255)"
  PAYMENT_CONFIRMED_DATE: "DATE"
  PAYMENT_AUTH_ID: "NUMBER"
  LOC_TYPE_ID: "NUMBER(2,0) → LOCATION TYPES"
  LOC_ID: "NUMBER(6,0) → LOCATIONS / OFFICES"
  SEND_AMEND_EMAIL: "CHAR(1)"
  AMEND_ACKN_SENT: "DATE"
  CANCELLED_BY: "VARCHAR2(255)"
  CANCELLED_DATE: "DATE"
  CANCELLED_OTHER_REASON: "VARCHAR2(4000)"
  JI_FP_CANCELLER_ID: "NUMBER(2,0)" {constraint: [foreign_key]}
  CANCEL_EMAIL_SENT: "CHAR(1)"
  CANCEL_ACKN_SENT: "DATE"
  LATE_CANCELLATION: "CHAR(1)"
  CANCELLED: "CHAR(1)"
  LAST_MODIFIED_BY: "VARCHAR2(255)"
  LAST_MODIFIED_DATE: "DATE"
  VERIFIED_BY: "VARCHAR2(255)"
  VERIFIED_DATE: "DATE"
  VERIFIED_FLAG: "NUMBER(1,0)"
  PAYROLL_NO: "NUMBER(8,0)"
  PAYMENT_RECONCILED_BY: "VARCHAR2(255)"
  PAYMENT_RECONCILED_DATE: "DATE"
  HEARING_LOC_TYPE_ID: "NUMBER(2,0) → LOCATION TYPES"
  HEARING_LOC_ID: "NUMBER(6,0) → LOCATIONS"
  BE_CODE_OVERRIDE: "VARCHAR2(5)"
  BOOKED_OVER_MAX: "CHAR(1)"
  EXTRA_ITIN_TEXT: "VARCHAR2(4000)"
  COST_CENTRE_CODE_OVERRIDE: "VARCHAR2(30)"
  JUDGE_CODE_OVERRIDE: "NUMBER(6,0)"
}

TBL_JI_FP_BOOKING_TYPES: "TBL_JI_FP_BOOKING_TYPES" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_FP_BOOKING_TYPE_ID: "NUMBER(2,0)" {constraint: [primary_key]}
  JI_FP_BOOKING_TYPE_NAME: "VARCHAR2(100)"
  IN_USE: "CHAR(1)"
}

TBL_JI_FP_CANCELLERS: "TBL_JI_FP_CANCELLERS" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_FP_CANCELLER_ID: "NUMBER(2,0)" {constraint: [primary_key]}
  JI_FP_CANCELLER_NAME: "VARCHAR2(100)"
  IN_USE: "CHAR(1)"
}

TBL_JI_PLANNED_SITTINGS: "TBL_JI_PLANNED_SITTINGS [BI BU]" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_PLANNED_SITTING_ID: "NUMBER" {constraint: [primary_key]}
  JI_PLANNED_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_PLANNED_WORK_TYPES"
  LOC_TYPE_ID: "NUMBER(2,0) → LOCATION TYPES"
  LOC_ID: "NUMBER(6,0) → LOCATIONS / OFFICES"
  CUT_COURTROOM_ID: "NUMBER → COURTROOMS / CUT_*"
  JUDGE_CODE: "NUMBER(6,0) → TBL_JUDGES"
  SITTING_DATE: "DATE"
  SITTING_DUR_ID: "NUMBER(2,0)"
  COMMENTS: "VARCHAR2(4000)"
  CREATED_BY: "VARCHAR2(255)"
  CREATED_DATE: "DATE"
  LAST_MODIFIED_BY: "VARCHAR2(255)"
  LAST_MODIFIED_DATE: "DATE"
  CANCELLED: "CHAR(1)"
  ACKNOWLEDGED_BY: "VARCHAR2(255)"
  ACKNOWLEDGED_DATE: "DATE"
  CANCELLED_BY: "VARCHAR2(255)"
  CANCELLED_DATE: "DATE"
  CANCELLED_OTHER_REASON: "VARCHAR2(4000)"
  JI_CHANGE_FROM_ID: "NUMBER"
  JI_CHANGE_TO_ID: "NUMBER"
  CUT_OWNER_ID: "NUMBER → COURTROOMS / CUT_*"
  YEARMONTH: "NUMBER(6,0)"
  JI_ACTUAL_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_ACTUAL_WORK_TYPES"
  CONFIRMED_BY: "VARCHAR2(255)"
  CONFIRMED_DATE: "DATE"
  SEND_AMEND_EMAIL: "CHAR(1)"
  AMEND_ACKN_SENT: "DATE"
  SITTING_TYPE_ID: "NUMBER(2,0) → Sitting Type lookup"
  VERIFIED_BY: "VARCHAR2(255)"
  VERIFIED_DATE: "DATE"
  VERIFIED_FLAG: "NUMBER(1,0)"
  HEARING_LOC_TYPE_ID: "NUMBER(2,0) → LOCATION TYPES"
  HEARING_LOC_ID: "NUMBER(6,0) → LOCATIONS"
  EXTRA_ITIN_TEXT: "VARCHAR2(4000)"
  LEGAL_ADV_WITH_MAGS: "CHAR(1)"
  LEGAL_ADV_SIT_TYPE: "NUMBER(1,0)"
}

TBL_JI_FP_BOOKING_DETAIL.JI_FP_BOOKING_ID -> TBL_JI_FP_BOOKINGS.JI_FP_BOOKING_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_FP_BOOKING_DETAIL.JI_FP_CANCELLER_ID -> TBL_JI_FP_CANCELLERS.JI_FP_CANCELLER_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_FP_BOOKINGS.JI_FP_BOOKING_TYPE_ID -> TBL_JI_FP_BOOKING_TYPES.JI_FP_BOOKING_TYPE_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_FP_BOOKINGS.JI_FP_CANCELLER_ID -> TBL_JI_FP_CANCELLERS.JI_FP_CANCELLER_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }

legend: |md
  **Legend** — `PK` primary · `FK` in-area (line) · `UNQ` unique · `→ TBL_X` cross-area ref (no line) · `→ hint` external (not in PDF)  
  ━━ blue solid = HIGH-confidence FK · - - grey dashed = MEDIUM-confidence FK
| { near: bottom-center; style.font-size: 13 }
