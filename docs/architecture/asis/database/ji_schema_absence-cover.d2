vars: { d2-config: { layout-engine: elk } }
direction: right

title: |md
  ## JI as-is schema — Absence & Cover Workflow
  PK / FK (in-area) / UNQ markers · trigger badges `[B/A × I/U/D]` · intra-area FK edges only · cross-area & external refs shown in the type cell
| { near: top-center; style.font-size: 22 }

TBL_JI_ABS_OB: "TBL_JI_ABS_OB [BI]" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_ABS_OB_ID: "NUMBER" {constraint: [primary_key]}
  JI_ABS_OB_TYPE_ID: "NUMBER(3,0)" {constraint: [foreign_key]}
  JUDGE_CODE: "NUMBER(6,0) → TBL_JUDGES"
  START_DATE: "DATE"
  END_DATE: "DATE"
  WORKING_DAYS: "NUMBER(5,2)"
  COMMENTS: "VARCHAR2(4000)"
  CREATED_BY: "VARCHAR2(255)"
  CREATED_DATE: "DATE"
  LAST_MODIFIED_BY: "VARCHAR2(255)"
  LAST_MODIFIED_DATE: "DATE"
  CONFIRMED_BY: "VARCHAR2(255)"
  CONFIRMED_DATE: "DATE"
  CANCELLED: "CHAR(1)"
  ACKNOWLEDGED_BY: "VARCHAR2(255)"
  ACKNOWLEDGED_DATE: "DATE"
  START_SITTING_DUR_ID: "NUMBER(2,0)"
  END_SITTING_DUR_ID: "NUMBER(2,0)"
  JI_CHANGE_FROM_ID: "NUMBER"
  JI_CHANGE_TO_ID: "NUMBER"
  ABS_OB_LENGTH_TYPE_ID: "NUMBER(2,0) → Absence Length Type lookup"
  CANCELLED_BY: "VARCHAR2(255)"
  CANCELLED_DATE: "DATE"
  CANCELLED_OTHER_REASON: "VARCHAR2(4000)"
  JI_PLANNED_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_PLANNED_WORK_TYPES"
  JUDGE_TICKET_TYPE_ID: "NUMBER(3,0) → TBL_JUDGE_TICKET_TYPES"
  VAC_COMMENTS: "VARCHAR2(4000)"
  EMAIL_SENT: "CHAR(1)"
  FILL_ACTION_ID: "NUMBER(1,0) → Fill Action lookup"
  VAC_JUDGE_TYPE_ID: "NUMBER(3,0) → TBL_JUDGE_TYPES"
  CANCEL_EMAIL: "CHAR(1)"
  CANCEL_ACKN_DATE: "DATE"
  FEE_PAYABLE: "CHAR(1)"
  TOTAL_FEE_AMT: "NUMBER(8,2)"
  LINKED_SITTING_ID: "NUMBER"
  LINKED_BOOKING_DETAIL_ID: "NUMBER"
}

TBL_JI_ABS_OB_DETAIL: "TBL_JI_ABS_OB_DETAIL [BI]" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_ABS_OB_DETAIL_ID: "NUMBER" {constraint: [primary_key]}
  JI_ABS_OB_ID: "NUMBER" {constraint: [foreign_key]}
  ABS_OB_DATE: "DATE"
  YEARMONTH: "NUMBER(6,0)"
  SITTING_DUR_ID: "NUMBER(2,0)"
  LOC_TYPE_ID: "NUMBER(3,0) → LOCATION TYPES"
  LOC_ID: "NUMBER(6,0) → LOCATIONS / OFFICES"
  ABS_OB_STATUS_ID: "NUMBER(2,0)"
  CANCELLED: "CHAR(1)"
  CANCELLED_BY: "VARCHAR2(255)"
  CANCELLED_DATE: "DATE"
  CUT_OWNER_ID: "NUMBER → COURTROOMS / CUT_*"
  PAYMENT_CONFIRMED_BY: "VARCHAR2(255)"
  PAYMENT_CONFIRMED_DATE: "DATE"
  PAYMENT_AUTH_ID: "NUMBER"
  FEE_AMT: "NUMBER(7,2)"
  T_AND_S_AMT: "NUMBER(7,2)"
  PAYMENT_RECONCILED_BY: "VARCHAR2(255)"
  PAYMENT_RECONCILED_DATE: "DATE"
  JI_PLANNED_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_PLANNED_WORK_TYPES"
  BE_CODE_OVERRIDE: "VARCHAR2(5)"
  BOOKING_CONFIRMED_BY: "VARCHAR2(255)"
  BOOKING_CONFIRMED_DATE: "DATE"
  JI_ACTUAL_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_ACTUAL_WORK_TYPES"
  COST_CENTRE_CODE_OVERRIDE: "VARCHAR2(30)"
}

TBL_JI_ABS_OB_CATS: "TBL_JI_ABS_OB_CATS" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_ABS_OB_CAT_ID: "NUMBER(2,0)" {constraint: [primary_key]}
  JI_ABS_OB_CAT_NAME: "VARCHAR2(100)"
  IN_USE: "CHAR(1)"
  ABBR_NAME: "VARCHAR2(10)"
}

TBL_JI_ABS_OB_TYPES: "TBL_JI_ABS_OB_TYPES" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_ABS_OB_TYPE_ID: "NUMBER(3,0)" {constraint: [primary_key]}
  JI_ABS_OB_TYPE_NAME: "VARCHAR2(100)"
  IN_USE: "CHAR(1)"
  SD_STATUS: "NUMBER(1,0)"
  INCL_IN_ITIN: "CHAR(1)"
  ABS_OB_CAT_ID: "NUMBER(2,0)"
  ALLOW_WEEKEND: "CHAR(1)"
  FEE_PAYABLE: "CHAR(1)"
  ACTIVITY_DESC: "VARCHAR2(30)"
  INCL_IN_ITIN_FP: "CHAR(1)"
  MI_TYPE_ID: "NUMBER(2,0)"
  SD_STATUS_FP: "NUMBER(1,0)"
}

TBL_JI_ABS_OB_VAC_OPTS: "TBL_JI_ABS_OB_VAC_OPTS [BI]" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_ABS_OB_VAC_OPTS_ID: "NUMBER" {constraint: [primary_key]}
  JI_ABS_OB_ID: "NUMBER" {constraint: [foreign_key]}
  VAC_BLOCK_NO: "NUMBER(5,2)"
  VACANCY_DATE: "DATE"
  SITTING_DUR_ID: "NUMBER(2,0)"
  LOC_TYPE_ID: "NUMBER(3,0) → LOCATION TYPES"
  LOC_ID: "NUMBER(6,0) → LOCATIONS / OFFICES"
  CUT_OWNER_ID: "NUMBER → COURTROOMS / CUT_*"
  JI_PLANNED_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_PLANNED_WORK_TYPES"
  JUDGE_TICKET_TYPE_ID: "NUMBER(3,0) → TBL_JUDGE_TICKET_TYPES"
  VACANCY_STATUS_ID: "NUMBER(2,0) → Vacancy Status lookup"
  CREATED_BY: "VARCHAR2(255)"
  CREATED_DATE: "DATE"
  APPROVED_BY: "VARCHAR2(255)"
  APPROVED_DATE: "DATE"
  LAST_MODIFIED_BY: "VARCHAR2(255)"
  LAST_MODIFIED_DATE: "DATE"
  CANCELLED: "CHAR(1)"
  COMMENTS: "VARCHAR2(4000)"
  JI_VACANCY_GROUP_ID: "NUMBER" {constraint: [foreign_key]}
  VAC_JUDGE_TYPE_ID: "NUMBER(3,0) → TBL_JUDGE_TYPES"
  JI_ABS_OB_DETAIL_ID: "NUMBER" {constraint: [foreign_key]}
}

TBL_JI_VACANCIES: "TBL_JI_VACANCIES [BI BU]" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_VACANCY_ID: "NUMBER" {constraint: [primary_key]}
  JI_ABS_OB_DETAIL_ID: "NUMBER" {constraint: [foreign_key]}
  JI_ABS_OB_ID: "NUMBER" {constraint: [foreign_key]}
  VACANCY_DATE: "DATE"
  YEARMONTH: "NUMBER(6,0)"
  SITTING_DUR_ID: "NUMBER(2,0)"
  LOC_TYPE_ID: "NUMBER(3,0) → LOCATION TYPES"
  LOC_ID: "NUMBER(6,0) → LOCATIONS / OFFICES"
  CUT_OWNER_ID: "NUMBER → COURTROOMS / CUT_*"
  JI_PLANNED_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_PLANNED_WORK_TYPES"
  JUDGE_TICKET_TYPE_ID: "NUMBER(3,0) → TBL_JUDGE_TICKET_TYPES"
  ABS_OB_JUDGE_CODE: "NUMBER(6,0) → TBL_JUDGES"
  CREATED_BY: "VARCHAR2(255)"
  CREATED_DATE: "DATE"
  LAST_MODIFIED_BY: "VARCHAR2(255)"
  LAST_MODIFIED_DATE: "DATE"
  CANCELLED: "CHAR(1)"
  CANCELLED_BY: "VARCHAR2(255)"
  CANCELLED_DATE: "DATE"
  CANCELLED_OTHER_REASON: "VARCHAR2(4000)"
  VACANCY_STATUS_ID: "NUMBER(2,0) → Vacancy Status lookup"
  COMMENTS: "VARCHAR2(4000)"
  JI_VACANCY_GROUP_ID: "NUMBER" {constraint: [foreign_key]}
  CANCELLED_REASON_ID: "NUMBER(2,0)"
  WORKING_DAYS_NOTICE: "NUMBER(4,0)"
  HEARING_LOC_TYPE_ID: "NUMBER(2,0) → LOCATION TYPES"
  HEARING_LOC_ID: "NUMBER(6,0) → LOCATIONS"
  BOOKING_DATE: "DATE"
}

TBL_JI_VACANCY_GROUPS: "TBL_JI_VACANCY_GROUPS [BI]" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_VACANCY_GROUP_ID: "NUMBER" {constraint: [primary_key]}
  JI_ABS_OB_ID: "NUMBER" {constraint: [foreign_key]}
  START_DATE: "DATE"
  END_DATE: "DATE"
  WORKING_DAYS: "NUMBER(5,2)"
  START_SITTING_DUR_ID: "NUMBER(2,0)"
  END_SITTING_DUR_ID: "NUMBER(2,0)"
  VAC_LENGTH_TYPE_ID: "NUMBER(2,0)"
  LOC_TYPE_ID: "NUMBER(3,0) → LOCATION TYPES"
  LOC_ID: "NUMBER(6,0) → LOCATIONS / OFFICES"
  CUT_OWNER_ID: "NUMBER → COURTROOMS / CUT_*"
  JI_PLANNED_WORK_TYPE_ID: "NUMBER(3,0) → TBL_JI_PLANNED_WORK_TYPES"
  JUDGE_TICKET_TYPE_ID: "NUMBER(3,0) → TBL_JUDGE_TICKET_TYPES"
  ABS_OB_JUDGE_CODE: "NUMBER(6,0) → TBL_JUDGES"
  CREATED_BY: "VARCHAR2(255)"
  CREATED_DATE: "DATE"
  LAST_MODIFIED_BY: "VARCHAR2(255)"
  LAST_MODIFIED_DATE: "DATE"
  CANCELLED: "CHAR(1)"
  CANCELLED_BY: "VARCHAR2(255)"
  CANCELLED_DATE: "DATE"
  CANCELLED_OTHER_REASON: "VARCHAR2(4000)"
  JI_CHANGE_FROM_ID: "NUMBER"
  JI_CHANGE_TO_ID: "NUMBER"
  VACANCY_STATUS_ID: "NUMBER(2,0) → Vacancy Status lookup"
  COMMENTS: "VARCHAR2(4000)"
  VAC_JUDGE_TYPE_ID: "NUMBER(3,0) → TBL_JUDGE_TYPES"
  CANCELLED_REASON_ID: "NUMBER(2,0)"
  REQUESTED_DATE: "DATE"
  HEARING_LOC_TYPE_ID: "NUMBER(2,0) → LOCATION TYPES"
  HEARING_LOC_ID: "NUMBER(6,0) → LOCATIONS"
  BOOKING_DATE: "DATE"
}

TBL_JI_VAC_CANCEL_REASONS: "TBL_JI_VAC_CANCEL_REASONS" {
  shape: sql_table
  style.fill: "#6e7781"
  JI_VAC_CANCEL_REASON_ID: "NUMBER(2,0)" {constraint: [primary_key]}
  JI_VAC_CANCEL_REASON_NAME: "VARCHAR2(100)"
  IN_USE: "CHAR(1)"
}

TBL_JI_ABS_OB.JI_ABS_OB_TYPE_ID -> TBL_JI_ABS_OB_TYPES.JI_ABS_OB_TYPE_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_ABS_OB_DETAIL.JI_ABS_OB_ID -> TBL_JI_ABS_OB.JI_ABS_OB_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_ABS_OB_VAC_OPTS.JI_ABS_OB_ID -> TBL_JI_ABS_OB.JI_ABS_OB_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_ABS_OB_VAC_OPTS.JI_VACANCY_GROUP_ID -> TBL_JI_VACANCY_GROUPS.JI_VACANCY_GROUP_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_ABS_OB_VAC_OPTS.JI_ABS_OB_DETAIL_ID -> TBL_JI_ABS_OB_DETAIL.JI_ABS_OB_DETAIL_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_VACANCIES.JI_ABS_OB_DETAIL_ID -> TBL_JI_ABS_OB_DETAIL.JI_ABS_OB_DETAIL_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_VACANCIES.JI_ABS_OB_ID -> TBL_JI_ABS_OB.JI_ABS_OB_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_VACANCIES.JI_VACANCY_GROUP_ID -> TBL_JI_VACANCY_GROUPS.JI_VACANCY_GROUP_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }
TBL_JI_VACANCY_GROUPS.JI_ABS_OB_ID -> TBL_JI_ABS_OB.JI_ABS_OB_ID: { style.stroke: "#1f6feb"; style.stroke-width: 2 }

legend: |md
  **Legend** — `PK` primary · `FK` in-area (line) · `UNQ` unique · `→ TBL_X` cross-area ref (no line) · `→ hint` external (not in PDF)  
  ━━ blue solid = HIGH-confidence FK · - - grey dashed = MEDIUM-confidence FK
| { near: bottom-center; style.font-size: 13 }
