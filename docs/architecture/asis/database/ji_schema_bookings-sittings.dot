digraph JI_Schema_bookings_sittings {
  graph [rankdir=TB, splines=true, overlap=false, nodesep=0.35, ranksep=0.7, newrank=true, bgcolor="white", fontname="Helvetica", fontsize=14, labelloc="t", label=<<b>JI as-is schema — Bookings &amp; Sittings</b><br/><font point-size="11">Full columns · PK/FK/UK markers · trigger badges · intra-area FK edges only</font>>];
  node [shape=plain, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9];

  subgraph cluster_main {
    label=<<b>Bookings &amp; Sittings</b>>;
    labeljust="l";
    labelloc="t";
    style="filled,rounded";
    fillcolor="#FCE4EC";
    color="#999";
    fontsize=12;
    margin=18;
    "TBL_JI_FP_BOOKINGS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_FP_BOOKINGS</b> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JI_FP_BOOKING_ID</i></font></td></tr><tr><td port="ji_fp_booking_id" align="left"><font face="monospace" point-size="10"><b>JI_FP_BOOKING_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="ji_planned_work_type_id" align="left"><font face="monospace" point-size="10"><i>JI_PLANNED_WORK_TYPE_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>TBL_JI_PLANNED_WORK_TYPES</i> NN</font></td></tr><tr><td port="ji_abs_ob_id" align="left"><font face="monospace" point-size="10"><i>JI_ABS_OB_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#888">→ <i>TBL_JI_ABS_OB</i></font></td></tr><tr><td port="judge_code" align="left"><font face="monospace" point-size="10"><i>JUDGE_CODE</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(6,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>TBL_JUDGES</i></font></td></tr><tr><td port="start_date" align="left"><font face="monospace" point-size="10">START_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="end_date" align="left"><font face="monospace" point-size="10">END_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></t