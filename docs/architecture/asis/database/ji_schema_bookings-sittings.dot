ace="monospace" point-size="10">EMAIL_SENT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="cancel_email_sent" align="left"><font face="monospace" point-size="10">CANCEL_EMAIL_SENT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="cancel_ackn_sent" align="left"><font face="monospace" point-size="10">CANCEL_ACKN_SENT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="fee_payable" align="left"><font face="monospace" point-size="10">FEE_PAYABLE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="cut_owner_id" align="left"><font face="monospace" point-size="10"><i>CUT_OWNER_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#888">→ <i>COURTROOMS / CUT_*</i></font></td></tr><tr><td port="late_cancellation" align="left"><font face="monospace" point-size="10">LATE_CANCELLATION</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="send_amend_email" align="left"><font face="monospace" point-size="10">SEND_AMEND_EMAIL</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="amend_ackn_sent" align="left"><font face="monospace" point-size="10">AMEND_ACKN_SENT</font></td><td align="left"><font face="monospace" point-size="9" co