digraph JI_Schema_audit_cross_cutting {
  graph [rankdir=TB, splines=true, overlap=false, nodesep=0.35, ranksep=0.7, newrank=true, bgcolor="white", fontname="Helvetica", fontsize=14, labelloc="t", label=<<b>JI as-is schema — Audit &amp; Cross-cutting</b><br/><font point-size="11">Full columns · PK/FK/UK markers · trigger badges · intra-area FK edges only</font>>];
  node [shape=plain, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9];

  subgraph cluster_main {
    label=<<b>Audit &amp; Cross-cutting</b>>;
    labeljust="l";
    labelloc="t";
    style="filled,rounded";
    fillcolor="#FFFDE7";
    color="#999";
    fontsize=12;
    margin=18;
    "TBL_JI_CHANGES" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_CHANGES</b> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JI_CHANGE_ID</i></font></td></tr><tr><td port="ji_change_id" align="left"><font face="monospace" point-size="10"><b>JI_CHANGE_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="ji_change_type_id" align="left"><font face="monospace" point-size="10">JI_CHANGE_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">FK NN</font></td></tr><tr><td port="comments" align="left"><font face="monospace" point-size="10">COMMENTS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="created_by" align="left"><font face="monospace" point-size="10">CREATED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="created_date" align="left"><font face="monospace" point-size="10">CREATED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];
    "TBL_JI_CHANGE_TYPES" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_CHANGE_TYPES</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JI_CHANGE_TYPE_ID</i></font></td></tr><tr><td port="ji_change_type_id" align="left"><font face="monospace" point-size="10"><b>JI_CHANGE_TYPE_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="ji_change_type_name" align="left"><font face="monospace" point-size="10">JI_CHANGE_TYPE_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="in_use" align="left"><font face="monospace" point-size="10">IN_USE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];
    "TBL_JI_RESTR_ITIN_USERS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_RESTR_ITIN_USERS</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: USER_ID, REGION_ID</i></font></td></tr><tr><td port="user_id" align="left"><font face="monospace" point-size="10"><b>USER_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="region_id" align="left"><font face="monospace" point-size="10"><i><b>REGION_ID</b></i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(6,0)</font></td><td align="left"><font point-size="9" color="#888">PK → <i>REGIONS</i> NN</font></td></tr><tr><td port="created_by" align="left"><font face="monospace" point-size="10">CREATED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="created_date" align="left"><font face="monospace" point-size="10">CREATED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];

    { rank=same; "TBL_JI_CHANGES"; "TBL_JI_CHANGE_TYPES"; }
    "TBL_JI_CHANGES" -> "TBL_JI_CHANGE_TYPES" [style=invis, weight=10];
    "TBL_JI_CHANGES" -> "TBL_JI_RESTR_ITIN_USERS" [style=invis, weight=5];
  }

  "TBL_JI_CHANGES":ji_change_type_id:e -> "TBL_JI_CHANGE_TYPES" [style="solid", color="#1f6feb", penwidth=1.4, arrowsize=0.7];

  "_legend" [shape=plain, label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white"><tr><td bgcolor="#d0d7de"><font point-size="10"><b>Legend</b></font></td></tr><tr><td align="left"><font point-size="9"><b>PK</b> primary · <b>FK</b> in-area (line) · <b>UK</b> unique · <b>NN</b> not null</font></td></tr><tr><td align="left"><font point-size="9"><i>col</i> → <i>TBL_X</i> — cross-area ref (no line)</font></td></tr><tr><td align="left"><font point-size="9"><i>col</i> → <i>hint</i> — external (not in PDF)</font></td></tr><tr><td align="left"><font point-size="9"><b>[BI/BU/AI/AU/…]</b> = trigger Before/After × Insert/Update/Delete</font></td></tr><tr><td align="left"><font point-size="9">━━ solid blue = HIGH FK · - - dashed = MEDIUM FK</font></td></tr></table>>];
  "TBL_JI_RESTR_ITIN_USERS" -> "_legend" [style=invis, weight=1, constraint=false];
    { rank=sink; "_legend"; "TBL_JI_RESTR_ITIN_USERS"; }
}