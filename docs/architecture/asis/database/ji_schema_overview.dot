digraph JI_Schema_Overview {
  graph [rankdir=TB, splines=true, overlap=false, nodesep=0.35, ranksep=0.6, newrank=true, bgcolor="white", fontname="Helvetica", fontsize=14, labelloc="t", label=<<b>JI as-is database schema — overview</b><br/><font point-size="11">46 production tables in 6 areas · inter-area FK relationships aggregated · 0 explicit FK constraints in source DDL</font>>];
  node [shape=plain, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=10];

  "_cluster_judges_profile" [label=<<table border="1" color="#999" cellborder="0" cellspacing="0" cellpadding="0" bgcolor="white"><tr><td bgcolor="#E3F2FD" align="center" cellpadding="6"><font point-size="13"><b>Judges Profile &amp; Reference</b></font><br/><font point-size="9" color="#57606a">8 tables</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES</font> <font point-size="9" color="#57606a">(31)</font> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES_MASTER</font> <font point-size="9" color="#57606a">(34)</font> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES_USER_LINKS</font> <font point-size="9" color="#57606a">(7)</font> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGE_TYPES</font> <font point-size="9" color="#57606a">(23)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGE_STATUSES</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGE_CIRCUITS</font> <font point-size="9" color="#57606a">(5)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_LEADERSHIP_JUDGE_TYPES</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGE_TYPE_PROMOTION</font> <font point-size="9" color="#57606a">(4)</font></td></tr></table>>];
  "_cluster_judges_patterns" [label=<<table border="1" color="#999" cellborder="0" cellspacing="0" cellpadding="0" bgcolor="white"><tr><td bgcolor="#E8F5E9" align="center" cellpadding="6"><font point-size="13"><b>Working Patterns, Tickets &amp; Stats</b></font><br/><font point-size="9" color="#57606a">11 tables</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES_WORK_PATTERNS</font> <font point-size="9" color="#57606a">(16)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES_WP_DETAIL</font> <font point-size="9" color="#57606a">(9)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES_JURIS_SPLIT</font> <font point-size="9" color="#57606a">(4)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGE_JURIS</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGE_TICKET_TYPES</font> <font point-size="9" color="#57606a">(4)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES_TICKETS</font> <font point-size="9" color="#57606a">(10)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGE_COURTS_LINK</font> <font point-size="9" color="#57606a">(10)</font> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGE_FEE_RATES</font> <font point-size="9" color="#57606a">(5)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES_ANNUAL_LEAVE</font> <font point-size="9" color="#57606a">(12)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES_BOOKING_STATS</font> <font point-size="9" color="#57606a">(8)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JUDGES_MONTHLY_STATS</font> <font point-size="9" color="#57606a">(85)</font></td></tr></table>>];
  "_cluster_absence_cover" [label=<<table border="1" color="#999" cellborder="0" cellspacing="0" cellpadding="0" bgcolor="white"><tr><td bgcolor="#FFF3E0" align="center" cellpadding="6"><font point-size="13"><b>Absence &amp; Cover Workflow</b></font><br/><font point-size="9" color="#57606a">8 tables</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_ABS_OB</font> <font point-size="9" color="#57606a">(36)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_ABS_OB_DETAIL</font> <font point-size="9" color="#57606a">(25)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_ABS_OB_CATS</font> <font point-size="9" color="#57606a">(4)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_ABS_OB_TYPES</font> <font point-size="9" color="#57606a">(12)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_ABS_OB_VAC_OPTS</font> <font point-size="9" color="#57606a">(22)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_VACANCIES</font> <font point-size="9" color="#57606a">(28)</font> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_VACANCY_GROUPS</font> <font point-size="9" color="#57606a">(32)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_VAC_CANCEL_REASONS</font> <font point-size="9" color="#57606a">(3)</font></td></tr></table>>];
  "_cluster_bookings_sittings" [label=<<table border="1" color="#999" cellborder="0" cellspacing="0" cellpadding="0" bgcolor="white"><tr><td bgcolor="#FCE4EC" align="center" cellpadding="6"><font point-size="13"><b>Bookings &amp; Sittings</b></font><br/><font point-size="9" color="#57606a">5 tables</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_FP_BOOKINGS</font> <font point-size="9" color="#57606a">(42)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_FP_BOOKING_DETAIL</font> <font point-size="9" color="#57606a">(46)</font> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_FP_BOOKING_TYPES</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_FP_CANCELLERS</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_PLANNED_SITTINGS</font> <font point-size="9" color="#57606a">(37)</font> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr></table>>];
  "_cluster_reference_work" [label=<<table border="1" color="#999" cellborder="0" cellspacing="0" cellpadding="0" bgcolor="white"><tr><td bgcolor="#F3E5F5" align="center" cellpadding="6"><font point-size="13"><b>Reference Data — Work, Durations, Areas, Links</b></font><br/><font point-size="9" color="#57606a">11 tables</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_PLANNED_WORK_TYPES</font> <font point-size="9" color="#57606a">(8)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_PLANNED_WORK_CATS</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_ACTUAL_WORK_TYPES</font> <font point-size="9" color="#57606a">(6)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_ACTUAL_WORK_CATS</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_SITTING_DURS</font> <font point-size="9" color="#57606a">(5)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_AREAS</font> <font point-size="9" color="#57606a">(5)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_EXTRA_NWDS</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_LOC_JT_AWD_LINKS</font> <font point-size="9" color="#57606a">(4)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_LOC_JT_PWD_LINKS</font> <font point-size="9" color="#57606a">(4)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_LOC_JT_SD_LINKS</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_UA_JT_LINKS</font> <font point-size="9" color="#57606a">(2)</font></td></tr></table>>];
  "_cluster_audit_cross_cutting" [label=<<table border="1" color="#999" cellborder="0" cellspacing="0" cellpadding="0" bgcolor="white"><tr><td bgcolor="#FFFDE7" align="center" cellpadding="6"><font point-size="13"><b>Audit &amp; Cross-cutting</b></font><br/><font point-size="9" color="#57606a">3 tables</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_CHANGES</font> <font point-size="9" color="#57606a">(5)</font> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_CHANGE_TYPES</font> <font point-size="9" color="#57606a">(3)</font></td></tr><tr><td align="left" cellpadding="3"><font face="monospace" point-size="11">TBL_JI_RESTR_ITIN_USERS</font> <font point-size="9" color="#57606a">(4)</font></td></tr></table>>];

  { rank=same; "_cluster_judges_profile"; "_cluster_judges_patterns"; "_cluster_absence_cover"; }
  { rank=same; "_cluster_bookings_sittings"; "_cluster_reference_work"; "_cluster_audit_cross_cutting"; }
  "_cluster_judges_profile" -> "_cluster_bookings_sittings" [style=invis, weight=20];

  "_cluster_absence_cover" -> "_cluster_judges_profile" [label="  6  ", color="#1f6feb", penwidth=1.75, arrowsize=0.9, fontcolor="#0a3069", constraint=false];
  "_cluster_absence_cover" -> "_cluster_reference_work" [label="  6  ", color="#1f6feb", penwidth=1.75, arrowsize=0.9, fontcolor="#0a3069", constraint=false];
  "_cluster_absence_cover" -> "_cluster_judges_patterns" [label="  4  ", color="#1f6feb", penwidth=1.50, arrowsize=0.9, fontcolor="#0a3069", constraint=false];
  "_cluster_reference_work" -> "_cluster_judges_profile" [label="  6  ", color="#1f6feb", penwidth=1.75, arrowsize=0.9, fontcolor="#0a3069", constraint=false];
  "_cluster_bookings_sittings" -> "_cluster_judges_profile" [label="  3  ", color="#1f6feb", penwidth=1.38, arrowsize=0.9, fontcolor="#0a3069", constraint=false];
  "_cluster_bookings_sittings" -> "_cluster_reference_work" [label="  5  ", color="#1f6feb", penwidth=1.62, arrowsize=0.9, fontcolor="#0a3069", constraint=false];
  "_cluster_bookings_sittings" -> "_cluster_absence_cover" [label="  2  ", color="#1f6feb", penwidth=1.25, arrowsize=0.9, fontcolor="#0a3069", constraint=false];
  "_cluster_bookings_sittings" -> "_cluster_judges_patterns" [label="  2  ", color="#1f6feb", penwidth=1.25, arrowsize=0.9, fontcolor="#0a3069", constraint=false];
  "_cluster_judges_patterns" -> "_cluster_judges_profile" [label="  10  ", color="#1f6feb", penwidth=2.25, arrowsize=0.9, fontcolor="#0a3069", constraint=false];
  "_cluster_judges_patterns" -> "_cluster_reference_work" [label="  1  ", color="#1f6feb", penwidth=1.12, arrowsize=0.9, fontcolor="#0a3069", constraint=false];

  "_legend" [shape=plain, label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white"><tr><td bgcolor="#d0d7de"><font point-size="10"><b>Legend</b></font></td></tr><tr><td align="left"><font point-size="9">Box = area · <font face="monospace">TBL_NAME (n)</font> = column count</font></td></tr><tr><td align="left"><font point-size="9">Arrow with N = inter-area FK count (line weight scales)</font></td></tr><tr><td align="left"><font point-size="9"><b>[BI/BU/…]</b> = trigger Before/After × Insert/Update/Delete</font></td></tr></table>>];
  "_cluster_audit_cross_cutting" -> "_legend" [style=invis, weight=10];
  { rank=sink; "_legend"; }
}