    "TBL_JI_PLANNED_WORK_TYPES" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_PLANNED_WORK_TYPES</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JI_PLANNED_WORK_TYPE_ID</i></font></td></tr><tr><td port="ji_planned_work_type_id" align="left"><font face="monospace" point-size="10"><b>JI_PLANNED_WORK_TYPE_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="ji_planned_work_type_name" align="left"><font face="monospace" point-size="10">JI_PLANNED_WORK_TYPE_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="in_use" align="left"><font face="monospace" point-size="10">IN_USE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="ji_planned_work_cat_id" align="left"><font face="monospace" point-size="10">JI_PLANNED_WORK_CAT_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">FK NN</font></td></tr><tr><td port="ji_actual_work_type_id" align="left"><font face="monospace" point-size="10">JI_ACTUAL_WORK_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#0969da">FK</font></td></tr><tr><td port="section_9" align="left"><font face="monospace" point-size="10">SECTION_9</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="linked_ticket_type_id" align="left"><font face="monospace" point-size="10">LINKED_TICKET_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="ji_actual_work_cat_id" align="left"><font face="monospace" point-size="10">JI_ACTUAL_WORK_CAT_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">FK NN</font></td></tr></table>>];
