    "TBL_JI_SITTING_DURS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_SITTING_DURS</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JI_SITTING_DUR_ID</i></font></td></tr><tr><td port="ji_sitting_dur_id" align="left"><font face="monospace" point-size="10"><b>JI_SITTING_DUR_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="ji_sitting_dur_name" align="left"><font face="monospace" point-size="10">JI_SITTING_DUR_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="days" align="left"><font face="monospace" point-size="10">DAYS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(4,2)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="in_use_abs_ob" align="left"><font face="monospace" point-size="10">IN_USE_ABS_OB</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="in_use_sittings" align="left"><font face="monospace" point-size="10">IN_USE_SITTINGS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];
    "TBL_JI_AREAS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_AREAS</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JI_AREA_ID</i></font></td></tr><tr><td port="ji_area_id" align="left"><font face="monospace" point-size="10"><b>JI_AREA_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(4,0)</font></td><td align="left"><font point-size="9" color="#0969da">PK</font></td></tr><tr><td port="ji_area_name" align="left"><font face="monospace" point-size="10">JI_AREA_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="ji_area_name_abbr" align="left"><font face="monospace" point-size="10">JI_AREA_NAME_ABBR</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="region_id" align="left"><font face="monospace" point-size="10"><i>REGION_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#888">→ <i>REGIONS</i> NN</font></td></tr><tr><td port="sort" align="left"><font face="monospace" point-size="10">SORT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(4,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];
    "TBL_JI_EXTRA_NWDS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_EXTRA_NWDS</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: NON_WORKING_DAY, JUDGE_TYPE_ID, JUDGE_CIRCUIT_CODE</i></font></td></tr><tr><td port="non_working_day" align="left"><font face="monospace" point-size="10"><b>NON_WORKING_DAY</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="judge_type_id" align="left"><font face="monospace" point-size="10"><i><b>JUDGE_TYPE_ID</b></i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#888">PK → <i>TBL_JUDGE_TYPES</i> NN</font></td></tr><tr><td port="judge_circuit_code" align="left"><font face="monospace" point-size="10"><i><b>JUDGE_CIRCUIT_CODE</b></i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(2)</font></td><td align="left"><font point-size="9" color="#888">PK → <i>TBL_JUDGE_CIRCUITS</i> NN</font></td></tr></table>>];
    "TBL_JI_LOC_JT_AWD_LINKS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_LOC_JT_AWD_LINKS</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: LOC_TYPE_ID, JUDGE_TYPE_ID, JI_ACTUAL_WORK_TYPE_ID</i></font></td></tr><tr><td port="loc_type_id" align="left"><font face="monospace" point-size="10"><i><b>LOC_TYPE_ID</b></i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(6,0)</font></td><td align="left"><font point-size="9" color="#888">PK → <i>LOCATION TYPES</i> NN</font></td></tr><tr><td port="judge_type_id" align="left"><font face="monospace" point-size="10"><i><b>JUDGE_TYPE_ID</b></i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#888">PK → <i>TBL_JUDGE_TYPES</i> NN</font></td></tr><tr><td port="ji_actual_work_type_id" align="left"><font face="monospace" point-size="10"><b>JI_ACTUAL_WORK_TYPE_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="role_specific" align="left"><font face="monospace" point-size="10">ROLE_SPECIFIC</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];
