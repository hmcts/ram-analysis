digraph JI_Schema_reference_work {
  graph [rankdir=TB, splines=true, overlap=false, nodesep=0.35, ranksep=0.7, newrank=true, bgcolor="white", fontname="Helvetica", fontsize=14, labelloc="t", label=<<b>JI as-is schema — Reference Data — Work, Durations, Areas, Links</b><br/><font point-size="11">Full columns · PK/FK/UK markers · trigger badges · intra-area FK edges only</font>>];
  node [shape=plain, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9];

  subgraph cluster_main {
    label=<<b>Reference Data — Work, Durations, Areas, Links</b>>;
    labeljust="l";
    labelloc="t";
    style="filled,rounded";
    fillcolor="#F3E5F5";
    color="#999";
    fontsize=12;
