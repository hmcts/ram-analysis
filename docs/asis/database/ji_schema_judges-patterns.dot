    { rank=same; "TBL_JUDGES_WORK_PATTERNS"; "TBL_JUDGES_WP_DETAIL"; "TBL_JUDGES_JURIS_SPLIT"; }
    "TBL_JUDGES_WORK_PATTERNS" -> "TBL_JUDGES_WP_DETAIL" [style=invis, weight=10];
    "TBL_JUDGES_WP_DETAIL" -> "TBL_JUDGES_JURIS_SPLIT" [style=invis, weight=10];
    { rank=same; "TBL_JUDGE_JURIS"; "TBL_JUDGE_TICKET_TYPES"; "TBL_JUDGES_TICKETS"; }
    "TBL_JUDGE_JURIS" -> "TBL_JUDGE_TICKET_TYPES" [style=invis, weight=10];
    "TBL_JUDGE_TICKET_TYPES" -> "TBL_JUDGES_TICKETS" [style=invis, weight=10];
    { rank=same; "TBL_JUDGE_COURTS_LINK"; "TBL_JUDGE_FEE_RATES"; "TBL_JUDGES_ANNUAL_LEAVE"; }
    "TBL_JUDGE_COURTS_LINK" -> "TBL_JUDGE_FEE_RATES" [style=invis, weight=10];
    "TBL_JUDGE_FEE_RATES" -> "TBL_JUDGES_ANNUAL_LEAVE" [style=invis, weight=10];
    { rank=same; "TBL_JUDGES_BOOKING_STATS"; "TBL_JUDGES_MONTHLY_STATS"; }
    "TBL_JUDGES_BOOKING_STATS" -> "TBL_JUDGES_MONTHLY_STATS" [style=invis, weight=10];
    "TBL_JUDGES_WORK_PATTERNS" -> "TBL_JUDGE_JURIS" [style=invis, weight=5];
    "TBL_JUDGE_JURIS" -> "TBL_JUDGE_COURTS_LINK" [style=invis, weight=5];
    "TBL_JUDGE_COURTS_LINK" -> "TBL_JUDGES_BOOKING_STATS" [style=invis, weight=5];
