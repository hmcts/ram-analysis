digraph JI_Schema_judges_patterns {
  graph [rankdir=TB, splines=true, overlap=false, nodesep=0.35, ranksep=0.7, newrank=true, bgcolor="white", fontname="Helvetica", fontsize=14, labelloc="t", label=<<b>JI as-is schema — Working Patterns, Tickets &amp; Stats</b><br/><font point-size="11">Full columns · PK/FK/UK markers · trigger badges · intra-area FK edges only</font>>];
  node [shape=plain, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9];

  subgraph cluster_main {
    label=<<b>Working Patterns, Tickets &amp; Stats</b>>;
    labeljust="l";
    labelloc="t";
    style="filled,rounded";
    fillcolor="#E8F5E9";
    color="#999";
    fontsize=12;
    margin=18;
    "TBL_JUDGES_WORK_PATTERNS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JUDGES_WORK_PATTERNS</b> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JUDGES_WORK_PATTERN_ID</i></font></td></tr><tr><td port="judges_work_pattern_id" align="left"><font face="monospace" point-size="10"><b>JUDGES_WORK_PATTERN_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="judges_master_id" align="left"><font face="monospace" point-size="10"><i>JUDGES_MASTER_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#888">→ <i>TBL_JUDGES_MASTER</i> NN</font></td></tr><tr><td port="work_pattern_type_id" align="left"><font face="monospace" point-size="10">WORK_PATTERN_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="start_date" align="left"><font face="monospace" point-size="10">START_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="end_date" align="left"><font face="monospace" point-size="10">END_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="comments" align="left"><font face="monospace" point-size="10">COMMENTS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="created_by" align="left"><font face="monospace" point-size="10">CREATED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="created_date" align="left"><font face="monospace" point-size="10">CREATED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="judge_code" align="left"><font face="monospace" point-size="10"><i>JUDGE_CODE</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(6,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>TBL_JUDGES</i> NN</font></td></tr><tr><td port="target_ann_sitting_days" align="left"><font face="monospace" point-size="10">TARGET_ANN_SITTING_DAYS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(4,1)</font></td><td align="left"> </td></tr><tr><td port="base_loc_type_id" align="left"><font face="monospace" point-size="10"><i>BASE_LOC_TYPE_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>LOCATION TYPES</i></font></td></tr><tr><td port="base_loc_id" align="left"><font face="monospace" point-size="10"><i>BASE_LOC_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(6,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>LOCATIONS</i></font></td></tr><tr><td port="fte_perc" align="left"><font face="monospace" point-size="10">FTE_PERC</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(5,2)</font></td><td align="left"> </td></tr><tr><td port="deleted" align="left"><font face="monospace" point-size="10">DELETED</font></td><td align="left"><font face="monospace" point-size="9" color