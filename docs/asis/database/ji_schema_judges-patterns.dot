lign="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="ji_planned_work_type_id" align="left"><font face="monospace" point-size="10"><i>JI_PLANNED_WORK_TYPE_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>TBL_JI_PLANNED_WORK_TYPES</i></font></td></tr><tr><td port="cut_owner_id" align="left"><font face="monospace" point-size="10"><i>CUT_OWNER_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#888">→ <i>COURTROOMS / CUT_*</i></font></td></tr><tr><td port="judge_code_override" align="left"><font face="monospace" point-size="10">JUDGE_CODE_OVERRIDE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(6,0)</font></td><td align="left"> </td></tr></table>>];
