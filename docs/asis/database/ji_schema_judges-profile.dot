    "TBL_JUDGES_USER_LINKS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JUDGES_USER_LINKS</b> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JUDGES_USER_LINKS_ID</i></font></td></tr><tr><td port="judges_user_links_id" align="left"><font face="monospace" point-size="10"><b>JUDGES_USER_LINKS_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="judges_master_id" align="left"><font face="monospace" point-size="10">JUDGES_MASTER_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">FK NN</font></td></tr><tr><td port="user_id" align="left"><font face="monospace" point-size="10">USER_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="created_by" align="left"><font face="monospace" point-size="10">CREATED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="created_date" align="left"><font face="monospace" point-size="10">CREATED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="last_modified_by" align="left"><font face="monospace" point-size="10">LAST_MODIFIED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="last_modified_date" align="left"><font face="monospace" point-size="10">LAST_MODIFIED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr></table>>];
    "TBL_JUDGE_TYPES" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JUDGE_TYPES</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JUDGE_TYPE_ID (from *_PK index)</i></font></td></tr><tr><td port="judge_type_id" align="left"><font face="monospace" point-size="10"><b>JUDGE_TYPE_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="judge_type_name" align="left"><font face="monospace" point-size="10">JUDGE_TYPE_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">UK NN</font></td></tr><tr><td port="in_use" align="left"><font face="monospace" point-size="10">IN_USE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="county" align="left"><font face="monospace" point-size="10">COUNTY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="crown" align="left"><font face="monospace" point-size="10">CROWN</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="rcj" align="left"><font face="monospace" point-size="10">RCJ</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="profile_judge_type_id" align="left"><font face="monospace" point-size="10">PROFILE_JUDGE_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="minimum" align="left"><font face="monospace" point-size="10">MINIMUM</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="mags" align="left"><font face="monospace" point-size="10">MAGS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="fwr" align="left"><font face="monospace" point-size="10">FWR</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="short_type_name" align="left"><font face="monospace" point-size="10">SHORT_TYPE_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(30)</font></td><td align="left"> </td></tr><tr><td port="salaried" align="left"><font face="monospace" point-size="10">SALARIED</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="fp_type_id" align="left"><font face="monospace" point-size="10">FP_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(1,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="locally_managed" align="left"><font face="monospace" point-size="10">LOCALLY_MANAGED</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="tribs" align="left"><font face="monospace" point-size="10">TRIBS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="daily_fee_amt" align="left"><font face="monospace" point-size="10">DAILY_FEE_AMT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(7,2)</font></td><td align="left"> </td></tr><tr><td port="daily_fee_amt_lw" align="left"><font face="monospace" point-size="10">DAILY_FEE_AMT_LW</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(7,2)</font></td><td align="left"> </td></tr><tr><td port="ann_sitting_comm" align="left"><font face="monospace" point-size="10">ANN_SITTING_COMM</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(5,2)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="sort" align="left"><font face="monospace" point-size="10">SORT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="rounding_factor" align="left"><font face="monospace" point-size="10">ROUNDING_FACTOR</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,2)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="judge_level" align="left"><font face="monospace" point-size="10">JUDGE_LEVEL</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="generic_fwr_text" align="left"><font face="monospace" point-size="10">GENERIC_FWR_TEXT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"> </td></tr><tr><td port="can_sit_in_retirement" align="left"><font face="monospace" point-size="10">CAN_SIT_IN_RETIREMENT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"> </td></tr></table>>];
    "TBL_JUDGE_STATUSES" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JUDGE_STATUSES</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JUDGE_STATUS_CODE</i></font></td></tr><tr><td port="judge_status_code" align="left"><font face="monospace" point-size="10"><b>JUDGE_STATUS_CODE</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(5)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="judge_status_name" align="left"><font face="monospace" point-size="10">JUDGE_STATUS_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="in_use" align="left"><font face="monospace" point-size="10">IN_USE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];
    "TBL_JUDGE_CIRCUITS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JUDGE_CIRCUITS</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JUDGE_CIRCUIT_CODE (from *_PK index)</i></font></td></tr><tr><td port="judge_circuit_code" align="left"><font face="monospace" point-size="10"><b>JUDGE_CIRCUIT_CODE</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(2)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="circuit_id" align="left"><font face="monospace" point-size="10">CIRCUIT_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="circuit_name" align="left"><font face="monospace" point-size="10">CIRCUIT_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="judge_circuit_name" align="left"><font face="monospace" point-size="10">JUDGE_CIRCUIT_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">UK NN</font></td></tr><tr><td port="in_use" align="left"><font face="monospace" point-size="10">IN_USE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];
    "TBL_LEADERSHIP_JUDGE_TYPES" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_LEADERSHIP_JUDGE_TYPES</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: LEADERSHIP_JUDGE_TYPE_ID</i></font></td></tr><tr><td port="leadership_judge_type_id" align="left"><font face="monospace" point-size="10"><b>LEADERSHIP_JUDGE_TYPE_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="leadership_judge_type_name" align="left"><font face="monospace" point-size="10">LEADERSHIP_JUDGE_TYPE_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="in_use" align="left"><font face="monospace" point-size="10">IN_USE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];
    "TBL_JUDGE_TYPE_PROMOTION" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JUDGE_TYPE_PROMOTION</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: (no PK declared)</i></font></td></tr><tr><td port="current_judge_type_id" align="left"><font face="monospace" point-size="10">CURRENT_JUDGE_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">FK NN</font></td></tr><tr><td port="promoted_judge_type_id" align="left"><font face="monospace" point-size="10">PROMOTED_JUDGE_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">FK NN</font></td></tr><tr><td port="last_modified_by" align="left"><font face="monospace" point-size="10">LAST_MODIFIED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"> </td></tr><tr><td port="last_modified_date" align="left"><font face="monospace" point-size="10">LAST_MODIFIED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr></table>>];

    { rank=same; "TBL_JUDGES"; "TBL_JUDGES_MASTER"; "TBL_JUDGES_USER_LINKS"; }
    "TBL_JUDGES" -> "TBL_JUDGES_MASTER" [style=invis, weight=10];
    "TBL_JUDGES_MASTER" -> "TBL_JUDGES_USER_LINKS" [style=invis, weight=10];
    { rank=same; "TBL_JUDGE_TYPES"; "TBL_JUDGE_STATUSES"; "TBL_JUDGE_CIRCUITS"; }
    "TBL_JUDGE_TYPES" -> "TBL_JUDGE_STATUSES" [style=invis, weight=10];
    "TBL_JUDGE_STATUSES" -> "TBL_JUDGE_CIRCUITS" [style=invis, weight=10];
    { rank=same; "TBL_LEADERSHIP_JUDGE_TYPES"; "TBL_JUDGE_TYPE_PROMOTION"; }
    "TBL_LEADERSHIP_JUDGE_TYPES" -> "TBL_JUDGE_TYPE_PROMOTION" [style=invis, weight=10];
    "TBL_JUDGES" -> "TBL_JUDGE_TYPES" [style=invis, weight=5];
    "TBL_JUDGE_TYPES" -> "TBL_LEADERSHIP_JUDGE_TYPES" [style=invis, weight=5];
  }

  "TBL_JUDGE_TYPE_PROMOTION":current_judge_type_id:e -> "TBL_JUDGE_TYPES" [style="dashed", color="#6c757d", penwidth=1.0, arrowsize=0.6];
  "TBL_JUDGE_TYPE_PROMOTION":promoted_judge_type_id:e -> "TBL_JUDGE_TYPES" [style="dashed", color="#6c757d", penwidth=1.0, arrowsize=0.6];
  "TBL_JUDGES":judge_type_id:e -> "TBL_JUDGE_TYPES" [style="solid", color="#1f6feb", penwidth=1.4, arrowsize=0.7];
  "TBL_JUDGES":judge_circuit_code:e -> "TBL_JUDGE_CIRCUITS" [style="solid", color="#1f6feb", penwidth=1.4, arrowsize=0.7];
  "TBL_JUDGES":judges_master_id:e -> "TBL_JUDGES_MASTER" [style="solid", color="#1f6feb", penwidth=1.4, arrowsize=0.7];
  "TBL_JUDGES_MASTER":current_judge_type_id:e -> "TBL_JUDGE_TYPES" [style="dashed", color="#6c757d", penwidth=1.0, arrowsize=0.6];
  "TBL_JUDGES_MASTER":current_main_judge_code:e -> "TBL_JUDGES" [style="dashed", color="#6c757d", penwidth=1.0, arrowsize=0.6];
  "TBL_JUDGES_USER_LINKS":judges_master_id:e -> "TBL_JUDGES_MASTER" [style="solid", color="#1f6feb", penwidth=1.4, arrowsize=0.7];

  "_legend" [shape=plain, label=<<table border="0" cellborder="1" cellspacing="0" cellpadding="3" bgcolor="white"><tr><td bgcolor="#d0d7de"><font point-size="10"><b>Legend</b></font></td></tr><tr><td align="left"><font point-size="9"><b>PK</b> primary · <b>FK</b> in-area (line) · <b>UK</b> unique · <b>NN</b> not null</font></td></tr><tr><td align="left"><font point-size="9"><i>col</i> → <i>TBL_X</i> — cross-area ref (no line)</font></td></tr><tr><td align="left"><font point-size="9"><i>col</i> → <i>hint</i> — external (not in PDF)</font></td></tr><tr><td align="left"><font point-size="9"><b>[BI/BU/AI/AU/…]</b> = trigger Before/After × Insert/Update/Delete</font></td></tr><tr><td align="left"><font point-size="9">━━ solid blue = HIGH FK · - - dashed = MEDIUM FK</font></td></tr></table>>];
  "TBL_JUDGE_TYPE_PROMOTION" -> "_legend" [style=invis, weight=1, constraint=false];
    { rank=sink; "_legend"; "TBL_JUDGE_TYPE_PROMOTION"; }
}