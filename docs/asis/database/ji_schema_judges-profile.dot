digraph JI_Schema_judges_profile {
  graph [rankdir=TB, splines=true, overlap=false, nodesep=0.35, ranksep=0.7, newrank=true, bgcolor="white", fontname="Helvetica", fontsize=14, labelloc="t", label=<<b>JI as-is schema — Judges Profile &amp; Reference</b><br/><font point-size="11">Full columns · PK/FK/UK markers · trigger badges · intra-area FK edges only</font>>];
  node [shape=plain, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9];

  subgraph cluster_main {
    label=<<b>Judges Profile &amp; Reference</b>>;
    labeljust="l";
    labelloc="t";
    style="filled,rounded";
    fillcolor="#E3F2FD";
    color="#999";
    fontsize=12;
    margin=18;
    "TBL_JUDGES" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JUDGES</b> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JUDGE_CODE (from *_PK index)</i></font></td></tr><tr><td port="judge_code" align="left"><font face="monospace" point-size="10"><b>JUDGE_CODE</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="judge_name" align="left"><font face="monospace" point-size="10">JUDGE_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="status" align="left"><font face="monospace" point-size="10">STATUS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(3)</font></td><td align="left"> </td></tr><tr><td port="judge_type_id" align="left"><font face="monospace" point-size="10">JUDGE_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">FK</font></td></tr><tr><td port="region_id" align="left"><font face="monospace" point-size="10"><i>REGION_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>REGIONS</i></font></td></tr><tr><td port="comments" align="left"><font face="monospace" point-size="10">COMMENTS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="judge_circuit_code" align="left"><font face="monospace" point-size="10">JUDGE_CIRCUIT_CODE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(2)</font></td><td align="left"><font point-size="9" color="#0969da">FK</font></td></tr><tr><td port="search" align="left"><font face="monospace" point-size="10">SEARCH</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="last_modified_by" align="left"><font face="monospace" point-size="10">LAST_MODIFIED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"> </td></tr><tr><td port="last_modified_date" align="left"><font face="monospace" point-size="10">LAST_MODIFIED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="hmcs_legal_tier_code" align="left"><font face="monospace" point-size="10"><i>HMCS_LEGAL_TIER_CODE</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(2)</font></td><td align="left"><font point-size="9" color="#888">→ <i>HMCS Legal Tier codes</i></font></td></tr><tr><td port="judges_master_id" align="left"><font face="monospace" point-size="10">JUDGES_MASTER_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">FK</font></td></tr><tr><td port="role_start_date" align="left"><font face="monospace" point-size="10">ROLE_START_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="role_end_date" align="left"><font face="monospace" point-size="10">ROLE_END_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="role_title_prefix" align="left"><font face="monospace" point-size="10">ROLE_TITLE_PREFIX</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="role_title_suffix" align="left"><font face="monospace" point-size="10">ROLE_TITLE_SUFFIX</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="itin_name" align="left"><font face="monospace" point-size="10">ITIN_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"> </td></tr><tr><td port="base_loc_type_id" align="left"><font face="monospace" point-size="10"><i>BASE_LOC_TYPE_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>LOCATION TYPES</i></font></td></tr><tr><td port="base_loc_id" align="left"><font face="monospace" point-size="10"><i>BASE_LOC_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(6,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>LOCATIONS</i></font></td></tr><tr><td port="next_status" align="left"><font face="monospace" point-size="10">NEXT_STATUS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(3)</font></td><td align="left"> </td></tr><tr><td port="min_ann_sitting_days" align="left"><font face="monospace" point-size="10">MIN_ANN_SITTING_DAYS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(4,1)</font></td><td align="left"> </td></tr><tr><td port="max_ann_sitting_days" align="left"><font face="monospace" point-size="10">MAX_ANN_SITTING_DAYS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(4,1)</font></td><td align="left"> </td></tr><tr><td port="itin_sort_name" align="left"><font face="monospace" point-size="10">ITIN_SORT_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(30)</font></td><td align="left"> </td></tr><tr><td port="payroll_no" align="left"><font face="monospace" point-size="10">PAYROLL_NO</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(8,0)</font></td><td align="left"> </td></tr><tr><td port="fp_status_id" align="left"><font face="monospace" point-size="10"><i>FP_STATUS_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(1,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>FP Status lookup</i> NN</font></td></tr><tr><td port="retirement_date" align="left"><font face="monospace" point-size="10">RETIREMENT_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="london_wt_status_id" align="left"><font face="monospace" point-size="10"><i>LONDON_WT_STATUS_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(1,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>London Weighting Status lookup</i> NN</font></td></tr><tr><td port="alt_judge_code" align="left"><font face="monospace" point-size="10">ALT_JUDGE_CODE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(8,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="renewal_date" align="left"><font face="monospace" point-size="10">RENEWAL_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="role_salutation" align="left"><font face="monospace" point-size="10">ROLE_SALUTATION</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="is_sitting_in_retirement" align="left"><font face="monospace" point-size="10">IS_SITTING_IN_RETIREMENT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"> </td></tr></table>>];
    "TBL_JUDGES_MASTER" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JUDGES_MASTER</b> <font color="#0a3069" point-size="9">[BI BU]</font></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JUDGES_MASTER_ID</i></font></td></tr><tr><td port="judges_master_id" align="left"><font face="monospace" point-size="10"><b>JUDGES_MASTER_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="title_prefix" align="left"><font face="monospace" point-size="10">TITLE_PREFIX</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="forename" align="left"><font face="monospace" point-size="10">FORENAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="initials" align="left"><font face="monospace" point-size="10">INITIALS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="surname" align="left"><font face="monospace" point-size="10">SURNAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="title_suffix" align="left"><font face="monospace" point-size="10">TITLE_SUFFIX</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="salutation" align="left"><font face="monospace" point-size="10">SALUTATION</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="email" align="left"><font face="monospace" point-size="10">EMAIL</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="phone1" align="left"><font face="monospace" point-size="10">PHONE1</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(30)</font></td><td align="left"> </td></tr><tr><td port="phone2" align="left"><font face="monospace" point-size="10">PHONE2</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(30)</font></td><td align="left"> </td></tr><tr><td port="payroll_no" align="left"><font face="monospace" point-size="10">PAYROLL_NO</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(8,0)</font></td><td align="left"> </td></tr><tr><td port="current_judge_type_id" align="left"><font face="monospace" point-size="10">CURRENT_JUDGE_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">FK NN</font></td></tr><tr><td port="current_status" align="left"><font face="monospace" point-size="10">CURRENT_STATUS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(3)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="current_loc_type_id" align="left"><font face="monospace" point-size="10">CURRENT_LOC_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"> </td></tr><tr><td port="current_loc_id" align="left"><font face="monospace" point-size="10">CURRENT_LOC_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(6,0)</font></td><td align="left"> </td></tr><tr><td port="other_contact_type" align="left"><font face="monospace" point-size="10">OTHER_CONTACT_TYPE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"> </td></tr><tr><td port="other_contact_name" align="left"><font face="monospace" point-size="10">OTHER_CONTACT_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="other_contact_email" align="left"><font face="monospace" point-size="10">OTHER_CONTACT_EMAIL</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="other_contact_phone1" align="left"><font face="monospace" point-size="10">OTHER_CONTACT_PHONE1</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(30)</font></td><td align="left"> </td></tr><tr><td port="other_contact_phone2" align="left"><font face="monospace" point-size="10">OTHER_CONTACT_PHONE2</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(30)</font></td><td align="left"> </td></tr><tr><td port="retirement_date" align="left"><font face="monospace" point-size="10">RETIREMENT_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="comments" align="left"><font face="monospace" point-size="10">COMMENTS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="search" align="left"><font face="monospace" point-size="10">SEARCH</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="created_by" align="left"><font face="monospace" point-size="10">CREATED_BY</font></td><td align="left"><font face="monospace" point-s