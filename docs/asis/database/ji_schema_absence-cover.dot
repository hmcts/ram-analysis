    "TBL_JI_VAC_CANCEL_REASONS" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_VAC_CANCEL_REASONS</b></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JI_VAC_CANCEL_REASON_ID</i></font></td></tr><tr><td port="ji_vac_cancel_reason_id" align="left"><font face="monospace" point-size="10"><b>JI_VAC_CANCEL_REASON_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="ji_vac_cancel_reason_name" align="left"><font face="monospace" point-size="10">JI_VAC_CANCEL_REASON_NAME</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(100)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="in_use" align="left"><font face="monospace" point-size="10">IN_USE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr></table>>];

