digraph JI_Schema_absence_cover {
  graph [rankdir=TB, splines=true, overlap=false, nodesep=0.35, ranksep=0.7, newrank=true, bgcolor="white", fontname="Helvetica", fontsize=14, labelloc="t", label=<<b>JI as-is schema — Absence &amp; Cover Workflow</b><br/><font point-size="11">Full columns · PK/FK/UK markers · trigger badges · intra-area FK edges only</font>>];
  node [shape=plain, fontname="Helvetica"];
  edge [fontname="Helvetica", fontsize=9];

  subgraph cluster_main {
    label=<<b>Absence &amp; Cover Workflow</b>>;
    labeljust="l";
    labelloc="t";
    style="filled,rounded";
    fillcolor="#FFF3E0";
    color="#999";
    fontsize=12;
    margin=18;
    "TBL_JI_ABS_OB" [label=<<table border="1" color="#57606a" cellborder="0" cellspacing="0" cellpadding="3"><tr><td bgcolor="#d0d7de" align="left" colspan="3"><b>TBL_JI_ABS_OB</b> <font color="#0a3069" point-size="9">[BI]</font></td></tr><tr><td bgcolor="#eaeef2" align="left" colspan="3"><font point-size="9"><i>PK: JI_ABS_OB_ID</i></font></td></tr><tr><td port="ji_abs_ob_id" align="left"><font face="monospace" point-size="10"><b>JI_ABS_OB_ID</b></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"><font point-size="9" color="#0969da">PK NN</font></td></tr><tr><td port="ji_abs_ob_type_id" align="left"><font face="monospace" point-size="10">JI_ABS_OB_TYPE_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#0969da">FK NN</font></td></tr><tr><td port="judge_code" align="left"><font face="monospace" point-size="10"><i>JUDGE_CODE</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(6,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>TBL_JUDGES</i> NN</font></td></tr><tr><td port="start_date" align="left"><font face="monospace" point-size="10">START_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="end_date" align="left"><font face="monospace" point-size="10">END_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="working_days" align="left"><font face="monospace" point-size="10">WORKING_DAYS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(5,2)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="comments" align="left"><font face="monospace" point-size="10">COMMENTS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="created_by" align="left"><font face="monospace" point-size="10">CREATED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="created_date" align="left"><font face="monospace" point-size="10">CREATED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="last_modified_by" align="left"><font face="monospace" point-size="10">LAST_MODIFIED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="last_modified_date" align="left"><font face="monospace" point-size="10">LAST_MODIFIED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="confirmed_by" align="left"><font face="monospace" point-size="10">CONFIRMED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="confirmed_date" align="left"><font face="monospace" point-size="10">CONFIRMED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="cancelled" align="left"><font face="monospace" point-size="10">CANCELLED</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="acknowledged_by" align="left"><font face="monospace" point-size="10">ACKNOWLEDGED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="acknowledged_date" align="left"><font face="monospace" point-size="10">ACKNOWLEDGED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="start_sitting_dur_id" align="left"><font face="monospace" point-size="10">START_SITTING_DUR_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="end_sitting_dur_id" align="left"><font face="monospace" point-size="10">END_SITTING_DUR_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="ji_change_from_id" align="left"><font face="monospace" point-size="10">JI_CHANGE_FROM_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"> </td></tr><tr><td port="ji_change_to_id" align="left"><font face="monospace" point-size="10">JI_CHANGE_TO_ID</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER</font></td><td align="left"> </td></tr><tr><td port="abs_ob_length_type_id" align="left"><font face="monospace" point-size="10"><i>ABS_OB_LENGTH_TYPE_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(2,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>Absence Length Type lookup</i></font></td></tr><tr><td port="cancelled_by" align="left"><font face="monospace" point-size="10">CANCELLED_BY</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(255)</font></td><td align="left"> </td></tr><tr><td port="cancelled_date" align="left"><font face="monospace" point-size="10">CANCELLED_DATE</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">DATE</font></td><td align="left"> </td></tr><tr><td port="cancelled_other_reason" align="left"><font face="monospace" point-size="10">CANCELLED_OTHER_REASON</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="ji_planned_work_type_id" align="left"><font face="monospace" point-size="10"><i>JI_PLANNED_WORK_TYPE_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>TBL_JI_PLANNED_WORK_TYPES</i></font></td></tr><tr><td port="judge_ticket_type_id" align="left"><font face="monospace" point-size="10"><i>JUDGE_TICKET_TYPE_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(3,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>TBL_JUDGE_TICKET_TYPES</i></font></td></tr><tr><td port="vac_comments" align="left"><font face="monospace" point-size="10">VAC_COMMENTS</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">VARCHAR2(4000)</font></td><td align="left"> </td></tr><tr><td port="email_sent" align="left"><font face="monospace" point-size="10">EMAIL_SENT</font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">CHAR(1)</font></td><td align="left"><font point-size="9" color="#0969da">NN</font></td></tr><tr><td port="fill_action_id" align="left"><font face="monospace" point-size="10"><i>FILL_ACTION_ID</i></font></td><td align="left"><font face="monospace" point-size="9" color="#57606a">NUMBER(1,0)</font></td><td align="left"><font point-size="9" color="#888">→ <i>Fill Action lookup</i></font></td></tr><tr><td port="vac_judge_type_id" align="left"><font face="monospace" point-size="10"><i>VAC_JUDGE_TYPE_ID</i></font>